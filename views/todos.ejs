<!DOCTYPE html>
<html lang="en">

<head>
  <%- await include("./views/layout/head.ejs", {title: title}) %> 
  <style>
    .matrix-2d {
      display: grid;
      grid-template-columns: minmax(100px, auto) 1fr 1fr;
      grid-template-areas:
        ".   l11 l12"
        "l21 c11 c12"
        "l22 c21 c22";
    }
  
    .label-top {
      padding: 1em 0 1em 1em;
      display: flex;
      align-items: center;
      justify-content: left;
    }
  
    .label-left {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 1em 1em 1em 0;
    }
  
    .label-1-1 {
      grid-area: l11;
    }
  
    .label-1-2 {
      grid-area: l12;
    }
  
    .label-2-1 {
      grid-area: l21;
    }
  
    .label-2-2 {
      grid-area: l22;
    }
  
    .content {
      padding: 1em;
    }
  
    .content-1-1 {
      grid-area: c11;
      background-color: lightgreen;
    }
  
    .content-1-2 {
      grid-area: c12;
      background-color: lightpink;
    }
  
    .content-2-1 {
      grid-area: c21;
      background-color: lightblue;
    }
  
    .content-2-2 {
      grid-area: c22;
      background-color: lightgray;
    }
  </style>
</head>

<header>
  <%- await include("./views/layout/header.ejs") %> 
</header>

<body>
  <form class="form-inline" action="/add-todo" method="POST">
    <input type="text" class="form-control mb-2 mr-sm-2" name="new-todo">
    <input type="checkbox" class="form-control mb-2 mr-sm-2" name="is-important" value="true">
    <label for="is-important">Important?</label>
    <input type="checkbox" class="form-control mb-2 mr-sm-2" name="is-urgent" value="true">
    <label for="is-urgent">Urgent?</label>
    <button type="submit" class="btn btn-primary mb-2">
      Add Todo
    </button>
  </form>

  <% if (error) { %> 
    <div class="alert alert-danger" role="alert">
      <%= error %> 
    </div>
  <% } %> 

  <div class="matrix-2d">
    <div class="label-top label-1-1">
      Important
    </div>
    <div class="label-top label-1-2">
      Not Important
    </div>
    <div class="label-left label-2-1">
      Urgent
    </div>
    <div class="label-left label-2-2">
      Not Urgent
    </div>
    <div class="content content-1-1">
      <%- await include('./views/layout/todo-list.ejs', {
        todos: todos.filter(todo => todo.isImportant && todo.isUrgent),
      }) %> 
    </div>
    <div class="content content-1-2">
      <%- await include('./views/layout/todo-list.ejs', {
        todos: todos.filter(todo => !todo.isImportant && todo.isUrgent),
      }) %> 
    </div>
    <div class="content content-2-1">
      <%- await include('./views/layout/todo-list.ejs', {
        todos: todos.filter(todo => todo.isImportant && !todo.isUrgent),
      }) %> 
    </div>
    <div class="content content-2-2">
      <%- await include('./views/layout/todo-list.ejs', {
        todos: todos.filter(todo => !todo.isImportant && !todo.isUrgent),
      }) %> 
    </div>
  </div>
</body>

<footer>
  <%- await include("./views/layout/footer.ejs") %> 
</footer>

</html>