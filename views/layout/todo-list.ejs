<ul class="list-group">
  <% for (todo of todos) { %>
    <a href="/todo/<%= todo._id %>">
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <div> <%= todo.name %> </div>
        <form action="/delete-todo/<%= todo._id %>" method="POST">
          <button type="submit" class="btn btn-primary mb-2">
            Delete
          </button>
        </form>
      </li>
    </a>
    <% } %>
</ul>